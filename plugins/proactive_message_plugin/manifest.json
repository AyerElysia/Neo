{
  "name": "proactive_message_plugin",
  "version": "1.1.0",
  "description": "让 Bot 具有在用户长时间未回复时主动发消息的能力，并内置时间感知",
  "author": "Neo-MoFox Team",
  "dependencies": {
    "plugins": [],
    "components": []
  },
  "include": [
    {
      "component_type": "tool",
      "component_name": "wait_longer",
      "dependencies": [],
      "enabled": true
    },
    {
      "component_type": "tool",
      "component_name": "query_time",
      "dependencies": [],
      "enabled": true
    },
    {
      "component_type": "event_handler",
      "component_name": "on_message",
      "dependencies": [],
      "enabled": true
    },
    {
      "component_type": "event_handler",
      "component_name": "time_prompt_injector",
      "dependencies": [],
      "enabled": true
    }
  ],
  "entry_point": "plugin.py",
  "min_core_version": "1.0.0",
  "python_dependencies": [],
  "dependencies_required": true,
  "config": {
    "path": "config/plugins/proactive_message_plugin/config.toml",
    "reloadable": true
  }
}
